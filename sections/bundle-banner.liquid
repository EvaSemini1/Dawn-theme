{{ 'bundle-banner.css' | asset_url | stylesheet_tag }}
<section class="bundle-banner">

  {% assign bg_desktop = section.settings.background_image | image_url: width: 2000 %}
  {% assign bg_mobile = section.settings.background_image_mobile | image_url: width: 390 %}

  <div 
    class="bundle-banner__bg"
    style="
      --bg-desktop: url({{ bg_desktop }});
      --bg-mobile: url({{ bg_mobile | default: bg_desktop }});
    "
    role="img"
    aria-label="{{ section.settings.heading_text | escape }}">
  </div>

  <div class="bundle-banner__inner">

    <div class="bundle-banner__content">

      <!-- Desktop heading and subheading -->
      <div class="bundle-banner__text-desktop">
        {% if section.settings.heading_text != blank %}
          <h2 class="bundle-banner__heading">
            {{ section.settings.heading_text }}
            {% if section.settings.heading_highlight != blank %}
              <span 
                class="bundle-banner__highlight {% if section.settings.enable_gradient %}is-gradient{% endif %}"
                style="
                  --highlight-color: {{ section.settings.highlight_color }};
                  --gradient-1: {{ section.settings.gradient_color_1 }};
                  --gradient-2: {{ section.settings.gradient_color_2 }};
                ">
                {{ section.settings.heading_highlight }}
              </span>
            {% endif %}
          </h2>
        {% endif %}

        {% if section.settings.subheading_text != blank %}
          <p class="bundle-banner__subheading">
            {{ section.settings.subheading_text }}
          </p>
        {% endif %}

        {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
          <a href="{{ section.settings.cta_link }}" class="bundle-banner__cta">
            {{ section.settings.cta_label }}
          </a>
        {% endif %}
      </div>

      <!-- Mobile heading and subheading -->
      <div class="bundle-banner__text-mobile">
        {% if section.settings.heading_text_mobile != blank %}
           <h2 class="bundle-banner__heading-mobile">
            {{ section.settings.heading_text_mobile }}
            {% if section.settings.heading_highlight != blank %}
              <span 
                class="bundle-banner__highlight {% if section.settings.enable_gradient %}is-gradient{% endif %}"
                style="
                  --highlight-color: {{ section.settings.highlight_color }};
                  --gradient-1: {{ section.settings.gradient_color_1 }};
                  --gradient-2: {{ section.settings.gradient_color_2 }};
                ">
                {{ section.settings.heading_highlight }}
              </span>
            {% endif %}
          </h2>
        {% endif %}

        {% if section.settings.subheading_text_mobile != blank %}
          <p class="bundle-banner__subheading">
            {{ section.settings.subheading_text_mobile }}
          </p>
        {% endif %}

        {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
          <a href="{{ section.settings.cta_link }}" class="bundle-banner__cta">
            {{ section.settings.cta_label }}
          </a>
        {% endif %}
      </div>

    </div>

    <!-- Product image -->
    {% if section.settings.product_image %}
      <div class="bundle-banner__media">
        <img 
          src="{{ section.settings.product_image | image_url: width: 800 }}"
          alt="{{ section.settings.heading_text | escape }}"
          loading="lazy"
          width="800"
          height="800">
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Bundle Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Desktop heading",
      "default": "Spring Bundle Sale"
    },
    {
      "type": "text",
      "id": "heading_text_mobile",
      "label": "Mobile heading"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Highlighted text",
      "default": "30% OFF"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#ff6f61"
    },
    {
      "type": "checkbox",
      "id": "enable_gradient",
      "label": "Enable gradient",
      "default": false
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient color 1",
      "default": "#ff6f61"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#ff9a9e"
    },
    {
      "type": "text",
      "id": "subheading_text",
      "label": "Desktop subheading",
      "default": "Save on our exclusive bundles."
    },
    {
      "type": "text",
      "id": "subheading_text_mobile",
      "label": "Mobile subheading"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Desktop background image"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Mobile background image"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Bundle Banner"
    }
  ]
}
{% endschema %}